@charset "utf-8";

.image-container { line-height: 0; font-size: 0px; display: block; }

.image-container img { display: block; vertical-align: bottom; }

.reader-mode-source-image { position: absolute; left: -99999px; top: 0px; width: 1px; height: 1px; overflow: hidden; opacity: 0; pointer-events: none; }

.comic-images-wrapper { display: flex; flex-direction: column; line-height: 0; font-size: 0px; }

.comic-images-wrapper > div { line-height: 0; font-size: 0px; }

.page-break { margin: 0px auto; line-height: 0; width: 100%; font-size: 0px; }

.page-break.no-gaps { line-height: 0; }

@supports (-moz-appearance: none) {
  .image-container, .image-container img { margin-bottom: -1px; }
}

.page-break .theimage { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0px; width: 100%; height: auto; margin: 0px auto; }

.page-break .part { width: 100%; height: 100%; margin: 0px; padding: 0px; display: block; object-fit: cover; max-width: 100%; }

.page-break .part.pos-1 { grid-area: 1 / 1; }

.page-break .part.pos-2 { grid-area: 2 / 1; }

.page-break .part.pos-3 { grid-area: 2 / 2; }

.page-break .part.pos-4 { grid-area: 1 / 2; }

@media (max-width: 767px) {
  .page-break .theimage { display: flex; flex-direction: column; }
  .page-break .part { width: 100%; }
}

.page-break.loading { display: flex; justify-content: center; align-items: center; position: relative; padding: 32px 0px; margin: 0px -5%; overflow: hidden; }

@keyframes pulse { 
  0% { transform: scale(0.95); opacity: 0.8; }
  50% { transform: scale(1.05); opacity: 1; }
  100% { transform: scale(0.95); opacity: 0.8; }
}

@keyframes zigzagPathSpin { 
  0% { transform: translate(-20px, -20px) rotate(0deg); }
  20% { transform: translate(20px, -10px) rotate(72deg); }
  40% { transform: translate(-15px, 15px) rotate(144deg); }
  60% { transform: translate(15px) rotate(216deg); }
  80% { transform: translate(-20px, -15px) rotate(288deg); }
  100% { transform: translate(-20px, -20px) rotate(360deg); }
}

@keyframes loadingSpin { 
  0% { transform: rotate(0deg); }
  25% { transform: rotate(90deg); }
  50% { transform: rotate(180deg); }
  75% { transform: rotate(270deg); }
  100% { transform: rotate(360deg); }
}

@keyframes loadingRing { 
  0% { stroke-dashoffset: 0; }
  100% { stroke-dashoffset: -360; }
}

.reader-settings-slider { appearance: none; height: 6px; border-radius: 999px; background: rgba(255, 255, 255, 0.08); outline: none; cursor: pointer; }

.reader-settings-slider::-webkit-slider-thumb { appearance: none; width: 16px; height: 16px; border-radius: 50%; background: rgb(255, 255, 255); box-shadow: rgba(59, 130, 246, 0.3) 0px 0px 0px 3px, rgba(0, 0, 0, 0.4) 0px 2px 8px; cursor: pointer; transition: box-shadow 0.15s; }

.reader-settings-slider::-webkit-slider-thumb:hover { box-shadow: rgba(59, 130, 246, 0.4) 0px 0px 0px 5px, rgba(0, 0, 0, 0.5) 0px 2px 12px; }

.comic-images-wrapper.reader-mode-single { align-items: center; }

.comic-images-wrapper.reader-mode-single .image-container { margin-bottom: 0px !important; }

.comic-images-wrapper.reader-mode-double { gap: 0px; }

.comic-images-wrapper.reader-mode-double .image-container { margin-bottom: 0px !important; }

.loader { width: 44.8px; height: 44.8px; color: var(--primary); position: relative; background: radial-gradient(11.2px, currentcolor 94%, rgba(0, 0, 0, 0)); }

.loader::before { content: ""; position: absolute; inset: 0px; border-radius: 50%; background: radial-gradient(10.08px at right bottom, rgba(0, 0, 0, 0) 94%, currentcolor) left top / 22.4px 22.4px no-repeat, radial-gradient(10.08px at left bottom, rgba(0, 0, 0, 0) 94%, currentcolor) right top, radial-gradient(10.08px at right top, rgba(0, 0, 0, 0) 94%, currentcolor) left bottom, radial-gradient(10.08px at left top, rgba(0, 0, 0, 0) 94%, currentcolor) right bottom; animation: 1.5s cubic-bezier(0.3, 1, 0, 1) 0s infinite normal none running loader; }

@keyframes loader { 
